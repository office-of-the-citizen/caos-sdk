{
  "name": "@office-of-the-citizen/caos-sdk",
  "version": "0.4.0",
  "description": "Official SDK for communicating with the Constitutional Artificial Operating System (CAOS) — transport contracts and permanent snapshot distribution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./permanent": {
      "types": "./dist/permanent/index.d.ts",
      "import": "./dist/permanent/index.js",
      "default": "./dist/permanent/index.js"
    },
    "./participation": {
      "types": "./dist/participation/index.d.ts",
      "import": "./dist/participation/index.js",
      "default": "./dist/participation/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "node scripts/generate-runtime-identity.mjs",
    "prebuild": "npm run generate",
    "build": "tsc",
    "pretypecheck": "npm run generate",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "zod": "3.23.3"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "caos",
    "sdk",
    "constitutional-ai",
    "operating-system",
    "citizen",
    "nigeria",
    "governance",
    "public-records",
    "api-client"
  ],
  "author": "Office of the Citizen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/office-of-the-citizen/caos-sdk.git"
  },
  "homepage": "https://github.com/office-of-the-citizen/caos-sdk#readme",
  "bugs": {
    "url": "https://github.com/office-of-the-citizen/caos-sdk/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
